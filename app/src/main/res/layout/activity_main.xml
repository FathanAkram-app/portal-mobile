<?xml version="1.0" encoding="utf-8"?>
<!-- PORTRAIT layout. Landscape variant lives in layout-land/ with identical IDs. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <!-- Animated radar/glow backdrop (behind everything) -->
    <com.nexxuz.portal.ui.RadarBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/transparent">

        <!-- ── Header ── -->
        <include
            android:id="@+id/headerBar"
            layout="@layout/include_header" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/appTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabBackground="@drawable/tab_background"
            app:tabTextColor="@color/on_surface_variant_60"
            app:tabSelectedTextColor="@color/primary"
            app:tabTextAppearance="@style/PortalTabText"
            app:tabIndicator="@drawable/tab_indicator_glow"
            app:tabIndicatorColor="@color/primary"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorHeight="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/regionRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

        <!-- ── Content title row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/contentTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Semua Pos" />

            <TextView
                android:id="@+id/contentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant_60"
                android:textSize="12sp"
                tools:text="22 site" />
        </LinearLayout>

        <!-- ── Content area ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/sitesRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="16dp"
                    android:clipToPadding="false" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary" />

            <include
                android:id="@+id/emptyView"
                layout="@layout/include_empty" />
        </FrameLayout>

        <!-- ── Footer ── -->
        <TextView
            android:id="@+id/statusBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_container_lowest"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textColor="@color/on_surface_variant_60"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="System: Optimal — 0/0 Online" />

    </LinearLayout>
</FrameLayout>
