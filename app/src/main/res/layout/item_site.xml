<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/siteRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingVertical="8dp"
    android:background="?attr/selectableItemBackgroundBorderless"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp">

        <ImageView
            android:id="@+id/siteThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_site_thumb"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_pos"
            android:contentDescription="@string/app_name" />

        <View
            android:id="@+id/statusDot"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="top|end"
            android:layout_margin="2dp"
            android:background="@drawable/dot_checking" />
    </FrameLayout>

    <TextView
        android:id="@+id/siteName"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/on_surface_variant"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        tools:text="Pos Bayangan" />

    <TextView
        android:id="@+id/siteIp"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/on_surface_variant_60"
        android:textSize="8sp"
        tools:text="172.27.3.1:80" />

</LinearLayout>
