<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Always-dark cyber command theme -->
    <style name="Theme.Portal" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:colorBackground">@color/surface</item>
        <item name="colorSurface">@color/surface_container</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:windowBackground">@color/surface</item>

        <item name="android:statusBarColor">@color/surface_container_lowest</item>
        <item name="android:navigationBarColor">@color/surface_container_lowest</item>
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>
    </style>

    <!-- Command-style app tabs -->
    <style name="PortalTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

    <!-- Dark dialog theme so AlertDialogs match the cyber-command palette instead
         of the default light Material look. Used by the add/edit-site and other dialogs. -->
    <style name="Theme.Portal.Dialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorAccent">@color/primary</item>

        <item name="android:colorBackground">@color/surface_container</item>
        <item name="colorSurface">@color/surface_container</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>
        <item name="android:textColorAlertDialogListItem">@color/on_surface</item>

        <item name="android:windowBackground">@drawable/bg_dialog</item>
        <item name="materialAlertDialogTitleTextStyle">@style/PortalDialogTitle</item>
        <item name="buttonBarPositiveButtonStyle">@style/PortalDialogButton.Primary</item>
        <item name="buttonBarNegativeButtonStyle">@style/PortalDialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/PortalDialogButton</item>
    </style>

    <style name="PortalDialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PortalDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/primary_20</item>
    </style>

    <style name="PortalDialogButton.Primary">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
