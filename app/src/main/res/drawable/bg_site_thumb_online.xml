<?xml version="1.0" encoding="utf-8"?>
<!-- "Lit" thumb for online sites: faint cyan halo + bright cyan border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_10" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container_lowest" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/primary" />
        </shape>
    </item>
</layer-list>
