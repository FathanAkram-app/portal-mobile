<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow halo -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/online_glow" />
        </shape>
    </item>
    <!-- Inner dot -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="@color/online" />
            <stroke android:width="1dp" android:color="@color/surface_container_lowest" />
        </shape>
    </item>
</layer-list>
