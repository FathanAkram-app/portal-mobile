<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined input field — dark inset with a subtle outline that lights up cyan
     when focused (mirrors the desktop portal's form inputs). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container_lowest" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container_lowest" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/outline_variant" />
        </shape>
    </item>
</selector>
